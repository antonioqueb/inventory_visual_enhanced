<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="inventory_visual_enhanced.ProductDetails" owl="1">
        <div class="details-wrapper">
            
            <!-- BARRA DE SELECCIÓN MÓVIL -->
            <div class="mobile-select-bar" t-on-click="onMobileSelectAll">
                <div class="mobile-select-content">
                    <div class="checkbox-wrapper">
                        <input 
                            type="checkbox"
                            class="form-check-input"
                            t-att-checked="props.areAllCurrentProductSelected ? props.areAllCurrentProductSelected() : false"
                            t-on-change="onMobileSelectAll"
                        />
                    </div>
                    <span class="mobile-select-text">
                        <t t-if="props.areAllCurrentProductSelected and props.areAllCurrentProductSelected()">Deseleccionar todo</t>
                        <t t-else="">Seleccionar todo</t>
                    </span>
                </div>
            </div>

            <table class="o_inventory_details_table">
                <thead>
                    <tr>
                        <th class="col-checkbox">☑</th>
                        <th class="col-lot">Lote</th>
                        <th class="col-location">Ubicación</th>
                        <th t-if="hasTransitDetails" class="col-eta">ETA</th>
                        <th class="col-dimensions">Dimensiones</th>
                        <th class="col-color">Color</th>
                        <th class="col-tipo">Tipo</th>
                        <th class="col-bloque">Bloque</th>
                        <th class="col-atado">Atado</th>
                        <th class="col-pedimento">Pedimento</th>
                        <th class="col-contenedor">Contenedor</th>
                        <th class="col-packing-list">Packing List</th>
                        <th class="col-numero-placa">N. Placa</th>
                        <th class="col-ref-proveedor">Ref. Prov.</th>
                        <th class="col-icon">P</th>
                        <th class="col-icon">N</th>
                        <th class="col-icon">D</th>
                        <th class="col-icon">E</th>
                    </tr>
                </thead>

                <tbody>
                    <!-- BUCLE EXTERNO: Itera sobre los GRUPOS (Bloques) -->
                    <t t-foreach="groupedAndSortedDetails" t-as="group" t-key="group.blockName">
                        
                        <!-- SEPARADOR ENTRE BLOQUES: fila vacía antes de cada bloque excepto el primero -->
                        <tr t-if="!group_first" class="container-separator-row">
                            <td t-att-colspan="getDetailColspan()" style="height: 8px; padding: 0; border: none; background: transparent;"></td>
                        </tr>

                        <!-- BUCLE INTERNO: Itera sobre los detalles -->
                        <t t-foreach="group.items" t-as="detail" t-key="detail.id">
                            
                            <!-- SEPARADOR DE CONTENEDOR: fila vacía cuando cambia el contenedor dentro del mismo bloque -->
                            <tr t-if="detail._containerBreak" class="container-separator-row">
                                <td t-att-colspan="getDetailColspan()" style="height: 8px; padding: 0; border: none; background: transparent;"></td>
                            </tr>

                            <tr>
                                <!-- Checkbox -->
                                <td class="col-checkbox text-center">
                                    <div class="checkbox-wrapper" t-on-click.stop="">
                                        <input 
                                            type="checkbox"
                                            class="form-check-input cart-checkbox"
                                            t-att-checked="props.isInCart ? props.isInCart(detail.id) : false"
                                            t-att-disabled="detail.tiene_hold or detail.en_orden_venta"
                                            t-on-change="() => props.toggleCartSelection ? props.toggleCartSelection(detail) : null"
                                            t-att-title="detail.tiene_hold ? 'Lote con apartado activo' : (detail.en_orden_venta ? 'Lote en orden de venta confirmada' : '')"
                                        />
                                    </div>
                                </td>
                                
                                <!-- Lote -->
                                <td class="col-lot">
                                    <span t-esc="detail.lot_name"></span>
                                </td>
                                
                                <!-- Ubicación -->
                                <td class="col-location">
                                    <i class="fa fa-map-marker"></i>
                                    <span t-esc="detail.location_name"></span>
                                </td>

                                <!-- ETA FORMATEADO: se conserva como ya lo tenías -->
                                <td t-if="hasTransitDetails" class="col-eta">
                                    <t t-if="isTransitDetail(detail)">
                                        <span
                                            class="eta-pill"
                                            t-att-class="{ 'eta-pill--empty': !detail.eta }"
                                            t-att-title="detail.eta_source ? ('Fuente: ' + detail.eta_source) : ''"
                                        >
                                            <i class="fa fa-calendar"></i>
                                            <t t-esc="getEtaText(detail)"/>
                                        </span>
                                    </t>
                                    <t t-else="">
                                        <span class="text-muted">—</span>
                                    </t>
                                </td>
                                
                                <!-- Dimensiones -->
                                <td class="col-dimensions">
                                    <span class="dimensions-inline">
                                        <span class="dims-text">
                                            <t t-if="detail.alto and detail.ancho">
                                                <t t-esc="detail.alto"/>m × <t t-esc="detail.ancho"/>m
                                            </t>
                                            <t t-elif="!detail.alto and !detail.ancho">-</t>
                                            <t t-elif="detail.alto">
                                                <t t-esc="detail.alto"/>m
                                            </t>
                                            <t t-else="">
                                                <t t-esc="detail.ancho"/>m
                                            </t>
                                        </span>
                                        <strong class="dimensions-total-inline">
                                            <t t-esc="props.formatNumber(detail.quantity)"/> <t t-esc="getUnitLabel(detail.tipo)"/>
                                        </strong>
                                    </span>
                                </td>

                                <!-- Color -->
                                <td class="col-color">
                                    <span t-if="detail.color" t-esc="detail.color"></span>
                                    <span t-else="" class="text-muted">-</span>
                                </td>

                                <!-- Tipo -->
                                <td class="col-tipo">
                                    <span t-if="detail.tipo" t-esc="detail.tipo"></span>
                                    <span t-else="" class="text-muted">-</span>
                                </td>
                                
                                <td class="col-bloque">
                                    <span t-if="detail.bloque" t-esc="detail.bloque"></span>
                                    <span t-else="" class="text-muted">-</span>
                                </td>
                                
                                <td class="col-atado">
                                    <span t-if="detail.atado" t-esc="detail.atado"></span>
                                    <span t-else="" class="text-muted">-</span>
                                </td>
                                
                                <td class="col-pedimento">
                                    <span t-if="detail.pedimento" t-esc="detail.pedimento"></span>
                                    <span t-else="" class="text-muted">-</span>
                                </td>
                                
                                <td class="col-contenedor">
                                    <span t-if="detail.contenedor" t-esc="detail.contenedor"></span>
                                    <span t-else="" class="text-muted">-</span>
                                </td>

                                <!-- COLUMNA: PACKING LIST -->
                                <td class="col-packing-list">
                                    <button
                                        t-if="detail.has_packing_list"
                                        type="button"
                                        class="btn btn-link p-0 packing-list-link"
                                        t-on-click="(ev) => this.openPackingList(detail, ev)"
                                        t-att-title="getPackingListTitle(detail)"
                                    >
                                        <span class="badge rounded-pill bg-light text-primary border packing-list-chip">
                                            <i class="fa fa-external-link me-1"></i>
                                            <t t-esc="getPackingListLabel(detail)"/>
                                        </span>
                                    </button>

                                    <span t-else="" class="text-muted">-</span>
                                </td>

                                <td class="col-num-placa">
                                    <span t-if="detail.numero_placa" t-esc="detail.numero_placa"></span>
                                    <span t-else="" class="text-muted">-</span>
                                </td>
                                
                                <td class="col-ref-proveedor">
                                    <span t-if="detail.referencia_proveedor" t-esc="detail.referencia_proveedor"></span>
                                    <span t-else="" class="text-muted">-</span>
                                </td>
                                
                                <!-- ACCIONES -->
                                <td class="col-icon action-btn-cell">
                                    <button 
                                        type="button"
                                        class="icon-btn"
                                        t-att-class="{ 'has-photos': detail.cantidad_fotos > 0, 'no-content': detail.cantidad_fotos === 0 }"
                                        t-on-click="() => props.onPhotoClick(detail.id)"
                                    >
                                        <i class="fa fa-camera"></i>
                                    </button>
                                </td>
                                
                                <td class="col-icon action-btn-cell">
                                    <button 
                                        type="button"
                                        class="icon-btn"
                                        t-att-class="{ 'has-notes': detail.detalles_placa, 'no-content': !detail.detalles_placa }"
                                        t-on-click="() => props.onNotesClick(detail.id)"
                                    >
                                        <i class="fa fa-info-circle"></i>
                                    </button>
                                </td>
                                
                                <td class="col-icon action-btn-cell">
                                    <button 
                                        t-if="props.hasSalesPermissions"
                                        type="button"
                                        class="icon-btn has-details"
                                        t-on-click="() => props.onDetailsClick(detail.id)"
                                    >
                                        <i class="fa fa-history"></i>
                                    </button>
                                    <span t-else="" class="icon-btn no-content"><i class="fa fa-history"></i></span>
                                </td>
                                
                                <!-- COLUMNA E (Estado): Prioridad -> 1. Hold activo, 2. En orden de venta, 3. Sin estado -->
                                <td class="col-icon action-btn-cell">
                                    <!-- 1. Tiene hold activo -->
                                    <button 
                                        t-if="detail.tiene_hold"
                                        type="button"
                                        class="status-badge-btn status-hold-active"
                                        t-on-click="() => props.hasSalesPermissions ? props.onHoldClick(detail.id, detail.hold_info) : null"
                                        t-att-title="props.hasSalesPermissions ? 'Ver información del apartado' : 'Lote con apartado activo'"
                                        t-att-style="!props.hasSalesPermissions ? 'cursor: default;' : ''"
                                    >
                                        <i class="fa fa-hand-paper-o"></i>
                                    </button>

                                    <!-- 2. En orden de venta confirmada -->
                                    <button 
                                        t-elif="detail.en_orden_venta"
                                        type="button"
                                        class="status-badge-btn status-sale-order"
                                        t-on-click="() => props.onSaleOrderClick(detail.id, detail.sale_order_ids)"
                                        title="Ver orden de venta"
                                    >
                                        <i class="fa fa-usd"></i>
                                    </button>

                                    <!-- 3. Sin estado -->
                                    <span t-else="" class="status-badge-btn status-no-hold" title="Sin apartado">
                                        <i class="fa fa-hand-paper-o"></i>
                                    </span>
                                </td>
                            </tr>
                        </t>

                        <!-- FILA DE RESUMEN DEL BLOQUE -->
                        <tr class="group-summary-row" style="background-color: #f8f9fa; border-top: 2px solid #e9ecef;">
                            <td></td>
                            
                            <!-- Columna Lote: Vacía para no romper patrón visual -->
                            <td class="col-lot"></td>
                            
                            <td></td>

                            <td t-if="hasTransitDetails"></td>
                            
                            <!-- Columna Dimensiones: Total piezas + Total área -->
                            <td class="col-dimensions" style="font-weight: bold; color: #212529;">
                                <t t-set="typeLabel" t-value="'Placas'"/>
                                <t t-if="group.productType and group.productType.toLowerCase() === 'formato'">
                                    <t t-set="typeLabel" t-value="'Formatos'"/>
                                </t>
                                <t t-elif="group.productType and group.productType.toLowerCase() === 'pieza'">
                                    <t t-set="typeLabel" t-value="'Piezas'"/>
                                </t>
                                <span>
                                    <t t-esc="group.count"/> <t t-esc="typeLabel"/> |
                                    <t t-esc="props.formatNumber(group.totalArea)"/> <t t-esc="getUnitLabel(group.productType)"/>
                                </span>
                            </td>
                            
                            <td colspan="9"></td>
                            
                            <!-- Últimas columnas: Fin del Bloque -->
                            <td colspan="4" style="text-align: right; vertical-align: middle; padding-right: 15px; color: #6c757d; font-style: italic;">
                                <small>
                                    <span t-esc="group.blockName" style="font-weight: 600;"/>
                                </small>
                            </td>
                        </tr>
                        
                    </t>
                </tbody>
            </table>
            
            <div class="table-loading" t-if="props.details.length === 0">
                <div class="spinner"></div>
                <div class="loading-text">Cargando detalles...</div>
            </div>
        </div>
    </t>
</templates>