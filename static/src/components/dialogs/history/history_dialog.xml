<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="inventory_visual_enhanced.HistoryDialog" owl="1">
        <Dialog size="'xl'" contentClass="'h-100 ivh-history-dialog-shell'">
            <div class="o_history_dialog d-flex flex-column h-100">

                <!-- Botón de cierre propio para ocultar visualmente el header nativo de Odoo -->
                <button class="ivh-dialog-close" type="button" t-on-click="props.close" title="Cerrar">
                    <i class="fa fa-times"></i>
                </button>

                <!-- HERO / HEADER PREMIUM -->
                <div class="ivh-history-hero">
                    <div class="ivh-history-hero__icon">
                        <i class="fa fa-cube"></i>
                    </div>

                    <div class="ivh-history-hero__content">
                        <div class="ivh-history-hero__eyebrow">
                            Historial integral del lote
                        </div>

                        <h2 class="ivh-history-hero__title">
                            <t t-esc="history.general_info.product_name"/>
                        </h2>

                        <div class="ivh-history-hero__meta">
                            <span>
                                <i class="fa fa-barcode"></i>
                                Lote:
                                <strong t-esc="history.general_info.lot_name"></strong>
                            </span>

                            <span t-if="history.general_info.product_code">
                                <i class="fa fa-tag"></i>
                                Código:
                                <strong t-esc="history.general_info.product_code"></strong>
                            </span>

                            <span>
                                <i class="fa fa-map-marker"></i>
                                Ubicación:
                                <strong t-esc="history.general_info.ubicacion_actual"></strong>
                            </span>
                        </div>
                    </div>

                    <div class="ivh-history-hero__badges">
                        <span class="ivh-soft-badge ivh-soft-badge--neutral">
                            <i class="fa fa-calendar"></i>
                            <t t-esc="history.statistics.dias_en_inventario"/>
                            días en inventario
                        </span>

                        <span class="ivh-soft-badge ivh-soft-badge--strong">
                            Estado:
                            <strong t-esc="history.general_info.estado_actual"></strong>
                        </span>
                    </div>
                </div>

                <!-- NAVEGACIÓN POR PESTAÑAS -->
                <ul class="nav nav-tabs ivh-history-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button
                            class="nav-link"
                            t-att-class="{ active: isActiveTab('general') }"
                            t-on-click="() => this.switchTab('general')"
                            type="button"
                        >
                            <i class="fa fa-info-circle"></i>
                            General
                            <span class="ivh-tab-count">1</span>
                        </button>
                    </li>

                    <li class="nav-item" role="presentation" t-if="history.has_purchase_permissions">
                        <button
                            class="nav-link"
                            t-att-class="{ active: isActiveTab('purchase') }"
                            t-on-click="() => this.switchTab('purchase')"
                            type="button"
                        >
                            <i class="fa fa-shopping-cart"></i>
                            Compras
                            <span class="ivh-tab-count" t-esc="history.purchase_info.length"></span>
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button
                            class="nav-link"
                            t-att-class="{ active: isActiveTab('movements') }"
                            t-on-click="() => this.switchTab('movements')"
                            type="button"
                        >
                            <i class="fa fa-exchange"></i>
                            Movimientos
                            <span class="ivh-tab-count" t-esc="history.statistics.total_movimientos"></span>
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button
                            class="nav-link"
                            t-att-class="{ active: isActiveTab('sales') }"
                            t-on-click="() => this.switchTab('sales')"
                            type="button"
                        >
                            <i class="fa fa-usd"></i>
                            Ventas
                            <span class="ivh-tab-count" t-esc="history.sales_orders.length"></span>
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button
                            class="nav-link"
                            t-att-class="{ active: isActiveTab('reservations') }"
                            t-on-click="() => this.switchTab('reservations')"
                            type="button"
                        >
                            <i class="fa fa-hand-paper-o"></i>
                            Apartados
                            <span class="ivh-tab-count" t-esc="history.reservations.length"></span>
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button
                            class="nav-link"
                            t-att-class="{ active: isActiveTab('deliveries') }"
                            t-on-click="() => this.switchTab('deliveries')"
                            type="button"
                        >
                            <i class="fa fa-truck"></i>
                            Entregas
                            <span class="ivh-tab-count" t-esc="history.deliveries.length"></span>
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button
                            class="nav-link"
                            t-att-class="{ active: isActiveTab('log') }"
                            t-on-click="() => this.switchTab('log')"
                            type="button"
                        >
                            <i class="fa fa-list"></i>
                            Log General
                            <span t-if="history.general_logs" class="ivh-tab-count" t-esc="history.general_logs.length"></span>
                        </button>
                    </li>
                </ul>

                <!-- CONTENIDO -->
                <div class="tab-content ivh-history-content flex-grow-1 overflow-auto">

                    <!-- PESTAÑA GENERAL -->
                    <div t-if="isActiveTab('general')" class="tab-pane fade show active">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="ivh-card h-100">
                                    <div class="ivh-card__header">
                                        <h6>
                                            <i class="fa fa-info-circle"></i>
                                            Información básica
                                        </h6>
                                    </div>

                                    <div class="ivh-card__body">
                                        <table class="ivh-info-table">
                                            <tr>
                                                <td>Fecha de creación</td>
                                                <td t-esc="history.general_info.fecha_creacion"></td>
                                            </tr>
                                            <tr>
                                                <td>Estado actual</td>
                                                <td>
                                                    <span class="ivh-soft-badge ivh-soft-badge--strong" t-esc="history.general_info.estado_actual"></span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>Ubicación actual</td>
                                                <td t-esc="history.general_info.ubicacion_actual"></td>
                                            </tr>
                                            <tr>
                                                <td>Días en inventario</td>
                                                <td t-esc="history.statistics.dias_en_inventario"></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="ivh-card h-100">
                                    <div class="ivh-card__header">
                                        <h6>
                                            <i class="fa fa-cubes"></i>
                                            Cantidades m²
                                        </h6>
                                    </div>

                                    <div class="ivh-card__body">
                                        <table class="ivh-info-table">
                                            <tr>
                                                <td>Cantidad actual</td>
                                                <td class="text-end">
                                                    <span class="ivh-number-pill" t-esc="formatNumber(history.general_info.cantidad_actual)"></span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>Cantidad reservada</td>
                                                <td class="text-end">
                                                    <span class="ivh-number-pill ivh-number-pill--hold" t-esc="formatNumber(history.general_info.cantidad_reservada)"></span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>Cantidad disponible</td>
                                                <td class="text-end">
                                                    <span class="ivh-number-pill ivh-number-pill--success" t-esc="formatNumber(history.general_info.cantidad_disponible)"></span>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="ivh-card ivh-card--featured">
                                    <div class="ivh-card__header">
                                        <h6>
                                            <i class="fa fa-bar-chart"></i>
                                            Estadísticas generales
                                        </h6>
                                    </div>

                                    <div class="ivh-card__body">
                                        <div class="ivh-stats-grid">
                                            <div class="ivh-stat-card">
                                                <h3 t-esc="history.statistics.total_movimientos"></h3>
                                                <span>Movimientos</span>
                                            </div>
                                            <div class="ivh-stat-card">
                                                <h3 t-esc="history.statistics.total_entradas"></h3>
                                                <span>Entradas</span>
                                            </div>
                                            <div class="ivh-stat-card">
                                                <h3 t-esc="history.statistics.total_salidas"></h3>
                                                <span>Salidas</span>
                                            </div>
                                            <div class="ivh-stat-card">
                                                <h3 t-esc="history.statistics.total_ventas"></h3>
                                                <span>Ventas</span>
                                            </div>
                                            <div class="ivh-stat-card">
                                                <h3 t-esc="history.statistics.total_apartados"></h3>
                                                <span>Apartados</span>
                                            </div>
                                            <div class="ivh-stat-card">
                                                <h3 t-esc="history.statistics.total_entregas"></h3>
                                                <span>Entregas</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- PESTAÑA COMPRAS -->
                    <div t-if="isActiveTab('purchase') and history.has_purchase_permissions" class="tab-pane fade show active">
                        <t t-if="history.purchase_info.length === 0">
                            <div class="ivh-empty-state">
                                <i class="fa fa-shopping-cart"></i>
                                <p>No hay información de compras para este lote</p>
                            </div>
                        </t>

                        <t t-else="">
                            <t t-foreach="history.purchase_info" t-as="purchase" t-key="purchase_index">
                                <div class="ivh-card ivh-record-card mb-3">
                                    <div class="ivh-card__header">
                                        <h6>
                                            <i class="fa fa-file-text-o"></i>
                                            <t t-esc="purchase.orden_compra"/>
                                        </h6>
                                        <span class="ivh-soft-badge ivh-soft-badge--neutral" t-esc="purchase.estado"></span>
                                    </div>

                                    <div class="ivh-card__body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="ivh-field-block">
                                                    <span>Proveedor</span>
                                                    <strong t-esc="purchase.proveedor"></strong>
                                                </div>
                                                <div class="ivh-field-block">
                                                    <span>Fecha de orden</span>
                                                    <strong t-esc="purchase.fecha_orden"></strong>
                                                </div>
                                            </div>

                                            <div class="col-md-6 text-md-end">
                                                <div class="ivh-field-block">
                                                    <span>Cantidad</span>
                                                    <strong><t t-esc="formatNumber(purchase.cantidad)"/> m²</strong>
                                                </div>
                                                <div class="ivh-field-block">
                                                    <span>Precio unitario</span>
                                                    <strong t-esc="formatCurrency(purchase.precio_unitario, purchase.moneda)"></strong>
                                                </div>
                                                <div class="ivh-total-pill">
                                                    <span>Total</span>
                                                    <strong t-esc="formatCurrency(purchase.total, purchase.moneda)"></strong>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>

                    <!-- PESTAÑA MOVIMIENTOS -->
                    <div t-if="isActiveTab('movements')" class="tab-pane fade show active">
                        <t t-if="history.movements.length === 0">
                            <div class="ivh-empty-state">
                                <i class="fa fa-exchange"></i>
                                <p>No hay movimientos registrados</p>
                            </div>
                        </t>

                        <t t-else="">
                            <div class="ivh-table-wrap">
                                <table class="ivh-table">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Tipo</th>
                                            <th>Origen</th>
                                            <th>Destino</th>
                                            <th class="text-end">Cantidad</th>
                                            <th>Referencia</th>
                                            <th>Usuario</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="history.movements" t-as="movement" t-key="movement_index">
                                            <tr>
                                                <td><small t-esc="movement.fecha"></small></td>
                                                <td>
                                                    <span class="ivh-soft-badge ivh-soft-badge--neutral">
                                                        <i class="fa" t-att-class="movement.icon"></i>
                                                        <t t-esc="movement.tipo"/>
                                                    </span>
                                                </td>
                                                <td><small t-esc="movement.origen"></small></td>
                                                <td><small t-esc="movement.destino"></small></td>
                                                <td class="text-end"><strong t-esc="formatNumber(movement.cantidad)"></strong></td>
                                                <td><small t-esc="movement.referencia"></small></td>
                                                <td><small t-esc="movement.usuario"></small></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>

                    <!-- PESTAÑA VENTAS -->
                    <div t-if="isActiveTab('sales')" class="tab-pane fade show active">
                        <t t-if="history.sales_orders.length === 0">
                            <div class="ivh-empty-state">
                                <i class="fa fa-usd"></i>
                                <p>No hay órdenes de venta para este lote</p>
                            </div>
                        </t>

                        <t t-else="">
                            <t t-foreach="history.sales_orders" t-as="sale" t-key="sale_index">
                                <div class="ivh-card ivh-record-card ivh-record-card--sale mb-3">
                                    <div class="ivh-card__header">
                                        <h6>
                                            <i class="fa fa-file-text-o"></i>
                                            <t t-esc="sale.orden_venta"/>
                                        </h6>
                                        <span class="ivh-soft-badge ivh-soft-badge--success" t-esc="sale.estado"></span>
                                    </div>

                                    <div class="ivh-card__body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="ivh-field-block">
                                                    <span>Cliente</span>
                                                    <strong t-esc="sale.cliente"></strong>
                                                </div>
                                                <div class="ivh-field-block">
                                                    <span>Vendedor</span>
                                                    <strong t-esc="sale.vendedor"></strong>
                                                </div>
                                                <div class="ivh-field-block">
                                                    <span>Fecha de orden</span>
                                                    <strong t-esc="sale.fecha_orden"></strong>
                                                </div>
                                            </div>

                                            <div class="col-md-6 text-md-end">
                                                <div class="ivh-field-block">
                                                    <span>Cantidad</span>
                                                    <strong><t t-esc="formatNumber(sale.cantidad)"/> m²</strong>
                                                </div>
                                                <div class="ivh-field-block">
                                                    <span>Precio unitario</span>
                                                    <strong t-esc="formatCurrency(sale.precio_unitario, sale.moneda)"></strong>
                                                </div>
                                                <div class="ivh-total-pill ivh-total-pill--success">
                                                    <span>Total</span>
                                                    <strong t-esc="formatCurrency(sale.total, sale.moneda)"></strong>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>

                    <!-- PESTAÑA APARTADOS -->
                    <div t-if="isActiveTab('reservations')" class="tab-pane fade show active">
                        <t t-if="history.reservations.length === 0">
                            <div class="ivh-empty-state">
                                <i class="fa fa-hand-paper-o"></i>
                                <p>No hay apartados o reservas</p>
                            </div>
                        </t>

                        <t t-else="">
                            <t t-foreach="history.reservations" t-as="reservation" t-key="reservation_index">
                                <div class="ivh-card ivh-record-card ivh-record-card--hold mb-3"
                                     t-att-class="{
                                         'ivh-record-card--active': reservation.estado_raw === 'activo',
                                         'ivh-record-card--cancelled': reservation.estado_raw === 'cancelado',
                                         'ivh-record-card--expired': reservation.estado_raw === 'expirado'
                                     }">

                                    <div class="ivh-card__header">
                                        <h6>
                                            <i class="fa fa-hand-paper-o"></i>
                                            <t t-esc="reservation.tipo"/>
                                            <small t-if="reservation.name">
                                                — <t t-esc="reservation.name"/>
                                            </small>
                                        </h6>

                                        <div class="ivh-header-badges">
                                            <span t-if="reservation.estado_raw === 'activo' and reservation.dias_restantes" class="ivh-soft-badge ivh-soft-badge--hold">
                                                <i class="fa fa-clock-o"></i>
                                                <t t-esc="reservation.dias_restantes"/> días restantes
                                            </span>

                                            <span t-if="reservation.duracion_dias !== undefined" class="ivh-soft-badge ivh-soft-badge--neutral">
                                                <i class="fa fa-hourglass-half"></i>
                                                Duración:
                                                <t t-esc="reservation.duracion_dias"/> días
                                            </span>

                                            <span class="ivh-soft-badge"
                                                  t-att-class="{
                                                      'ivh-soft-badge--hold': reservation.estado_raw === 'activo',
                                                      'ivh-soft-badge--danger': reservation.estado_raw === 'cancelado',
                                                      'ivh-soft-badge--neutral': reservation.estado_raw === 'expirado'
                                                  }"
                                                  t-esc="reservation.estado">
                                            </span>
                                        </div>
                                    </div>

                                    <div class="ivh-card__body">
                                        <div class="row g-4">
                                            <div class="col-md-6">
                                                <div class="ivh-section-title">
                                                    <i class="fa fa-user"></i>
                                                    Cliente
                                                </div>
                                                <p class="ivh-main-value" t-esc="reservation.partner"></p>
                                                <p class="ivh-muted-value" t-if="reservation.partner_ref">
                                                    Ref: <t t-esc="reservation.partner_ref"/>
                                                </p>
                                                <p class="ivh-muted-value" t-if="reservation.partner_email">
                                                    <i class="fa fa-envelope"></i>
                                                    <t t-esc="reservation.partner_email"/>
                                                </p>

                                                <div class="ivh-section-title mt-3">
                                                    <i class="fa fa-id-badge"></i>
                                                    Vendedor
                                                </div>
                                                <p class="ivh-main-value" t-esc="reservation.vendedor"></p>
                                                <p class="ivh-muted-value" t-if="reservation.vendedor_email">
                                                    <i class="fa fa-envelope"></i>
                                                    <t t-esc="reservation.vendedor_email"/>
                                                </p>

                                                <div t-if="reservation.proyecto">
                                                    <div class="ivh-section-title mt-3">
                                                        <i class="fa fa-building"></i>
                                                        Proyecto
                                                    </div>
                                                    <p class="ivh-main-value" t-esc="reservation.proyecto"></p>
                                                </div>

                                                <div t-if="reservation.arquitecto">
                                                    <div class="ivh-section-title mt-3">
                                                        <i class="fa fa-pencil-square-o"></i>
                                                        Arquitecto
                                                    </div>
                                                    <p class="ivh-main-value" t-esc="reservation.arquitecto"></p>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <div class="ivh-section-title">
                                                    <i class="fa fa-calendar"></i>
                                                    Fechas
                                                </div>
                                                <table class="ivh-info-table ivh-info-table--compact mb-3">
                                                    <tr>
                                                        <td>Creación</td>
                                                        <td t-esc="reservation.fecha_creacion"></td>
                                                    </tr>
                                                    <tr>
                                                        <td>Inicio</td>
                                                        <td t-esc="reservation.fecha_inicio"></td>
                                                    </tr>
                                                    <tr>
                                                        <td>Expiración</td>
                                                        <td><strong t-esc="reservation.fecha_expiracion"></strong></td>
                                                    </tr>
                                                </table>

                                                <div class="ivh-section-title">
                                                    <i class="fa fa-history"></i>
                                                    Auditoría
                                                </div>
                                                <table class="ivh-info-table ivh-info-table--compact mb-3">
                                                    <tr>
                                                        <td>Creado por</td>
                                                        <td t-esc="reservation.creado_por"></td>
                                                    </tr>
                                                    <tr>
                                                        <td>Última modif.</td>
                                                        <td t-esc="reservation.ultima_modificacion"></td>
                                                    </tr>
                                                    <tr>
                                                        <td>Modificado por</td>
                                                        <td t-esc="reservation.modificado_por"></td>
                                                    </tr>
                                                </table>

                                                <div t-if="reservation.ubicacion">
                                                    <div class="ivh-section-title">
                                                        <i class="fa fa-map-marker"></i>
                                                        Ubicación
                                                    </div>
                                                    <p class="ivh-main-value" t-esc="reservation.ubicacion"></p>
                                                </div>
                                            </div>
                                        </div>

                                        <div t-if="reservation.cancel_info and (reservation.estado_raw === 'cancelado' or reservation.estado_raw === 'expirado')"
                                             class="ivh-alert-box ivh-alert-box--danger mt-3">
                                            <h6>
                                                <i class="fa fa-times-circle"></i>
                                                Información de cancelación
                                            </h6>

                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <span>Tipo</span>
                                                    <strong t-esc="reservation.cancel_info.tipo_cancelacion"></strong>
                                                </div>
                                                <div class="col-md-4">
                                                    <span>Cancelado por</span>
                                                    <strong t-esc="reservation.cancel_info.cancelado_por"></strong>
                                                </div>
                                                <div class="col-md-4">
                                                    <span>Fecha</span>
                                                    <strong t-esc="reservation.cancel_info.fecha_cancelacion"></strong>
                                                </div>
                                            </div>
                                        </div>

                                        <div t-if="reservation.hold_order_name" class="ivh-alert-box ivh-alert-box--link mt-3">
                                            <h6>
                                                <i class="fa fa-link"></i>
                                                Orden de reserva vinculada
                                            </h6>

                                            <div class="row g-3">
                                                <div class="col-md-4">
                                                    <span>Orden</span>
                                                    <strong t-esc="reservation.hold_order_name"></strong>
                                                </div>
                                                <div class="col-md-4" t-if="reservation.hold_order_state">
                                                    <span>Estado</span>
                                                    <strong t-esc="reservation.hold_order_state"></strong>
                                                </div>
                                                <div class="col-md-4" t-if="reservation.hold_order_sale">
                                                    <span>Orden de venta</span>
                                                    <strong t-esc="reservation.hold_order_sale"></strong>
                                                </div>
                                            </div>
                                        </div>

                                        <div t-if="reservation.notas" class="ivh-note-box mt-3">
                                            <h6>
                                                <i class="fa fa-sticky-note-o"></i>
                                                Notas
                                            </h6>
                                            <p t-esc="reservation.notas"></p>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>

                    <!-- PESTAÑA ENTREGAS -->
                    <div t-if="isActiveTab('deliveries')" class="tab-pane fade show active">
                        <t t-if="history.deliveries.length === 0">
                            <div class="ivh-empty-state">
                                <i class="fa fa-truck"></i>
                                <p>No hay entregas registradas</p>
                            </div>
                        </t>

                        <t t-else="">
                            <div class="ivh-table-wrap">
                                <table class="ivh-table">
                                    <thead>
                                        <tr>
                                            <th>Referencia</th>
                                            <th>Cliente</th>
                                            <th>Fecha Programada</th>
                                            <th>Fecha Efectiva</th>
                                            <th class="text-end">Cantidad</th>
                                            <th>Origen</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="history.deliveries" t-as="delivery" t-key="delivery_index">
                                            <tr>
                                                <td><strong t-esc="delivery.referencia"></strong></td>
                                                <td><t t-esc="delivery.cliente"/></td>
                                                <td><small t-esc="delivery.fecha_programada"></small></td>
                                                <td><small t-esc="delivery.fecha_efectiva"></small></td>
                                                <td class="text-end"><strong t-esc="formatNumber(delivery.cantidad)"></strong></td>
                                                <td><small t-esc="delivery.origen"></small></td>
                                                <td>
                                                    <span class="ivh-soft-badge ivh-soft-badge--neutral" t-esc="delivery.estado"></span>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>

                    <!-- PESTAÑA LOG GENERAL -->
                    <div t-if="isActiveTab('log')" class="tab-pane fade show active">
                        <t t-if="!history.general_logs or history.general_logs.length === 0">
                            <div class="ivh-empty-state">
                                <i class="fa fa-list-alt"></i>
                                <p>No hay registros en el log general para este lote.</p>
                            </div>
                        </t>

                        <t t-else="">
                            <div class="ivh-table-wrap">
                                <table class="ivh-table ivh-table--compact">
                                    <thead>
                                        <tr>
                                            <th style="width: 15%">Fecha</th>
                                            <th style="width: 15%">Usuario</th>
                                            <th style="width: 15%">Origen</th>
                                            <th>Descripción</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="history.general_logs" t-as="log" t-key="log_index">
                                            <tr>
                                                <td class="text-nowrap"><small t-esc="log.fecha"></small></td>
                                                <td><strong t-esc="log.usuario"></strong></td>
                                                <td>
                                                    <span class="ivh-soft-badge ivh-soft-badge--neutral" t-esc="log.origen"></span>
                                                </td>
                                                <td>
                                                    <span t-esc="log.descripcion"></span>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>

                </div>
            </div>

            <t t-set-slot="footer">
                <button class="btn ivh-footer-close-btn" t-on-click="props.close">
                    <i class="fa fa-times"></i>
                    Cerrar
                </button>
            </t>
        </Dialog>
    </t>

</templates>