<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="inventory_visual_enhanced.SaleOrderDialog" owl="1">
        <Dialog size="'xl'" title="''" contentClass="'o_sale_order_dialog_content o_sale_order_dialog_content_wood'">
            <div class="o_sale_order_dialog o_sale_order_dialog_premium o_sale_order_dialog_wood">

                <t t-if="!hasOrders">
                    <div class="sod-empty">
                        <button class="sod-floating-close" type="button" t-on-click="props.close" title="Cerrar">
                            <i class="fa fa-times"/>
                        </button>

                        <div class="sod-empty__orb">
                            <i class="fa fa-usd"/>
                        </div>

                        <h3>No hay orden de venta vinculada</h3>
                        <p>El lote está marcado como vendido, pero no se recibió la referencia de la venta.</p>
                    </div>
                </t>

                <t t-else="">
                    <!-- HEADER -->
                    <div class="sod-hero">
                        <button class="sod-floating-close sod-floating-close--hero" type="button" t-on-click="props.close" title="Cerrar">
                            <i class="fa fa-times"/>
                        </button>

                        <div class="sod-hero__pattern"/>
                        <div class="sod-hero__grain"/>

                        <div class="sod-hero__content">
                            <div class="sod-hero__left">
                                <div class="sod-hero__icon">
                                    <i class="fa fa-usd"/>
                                </div>

                                <div class="sod-hero__copy">
                                    <span class="sod-eyebrow">Venta vinculada</span>
                                    <h2>Información comercial del lote</h2>
                                    <p>Referencia, cliente, material y pago en una vista rápida.</p>
                                </div>
                            </div>

                            <div class="sod-hero__right">
                                <button
                                    type="button"
                                    class="sod-ref-card"
                                    t-on-click="openPrimarySaleOrder"
                                    title="Abrir orden de venta"
                                >
                                    <span>Referencia</span>
                                    <strong t-esc="primaryOrder.name"/>
                                </button>

                                <div class="sod-payment-hero">
                                    <div class="sod-payment-hero__top">
                                        <span t-att-class="paymentStatusClass">
                                            <i t-attf-class="fa #{paymentStatusIcon}"/>
                                            <t t-esc="paymentStatusLabel"/>
                                        </span>

                                        <strong t-esc="formatPercent(primaryOrder.payment_percentage)"/>
                                    </div>

                                    <div class="sod-payment-progress sod-payment-progress--hero">
                                        <div
                                            class="sod-payment-progress__bar"
                                            t-att-style="'width: ' + clampPercentage(primaryOrder.payment_percentage) + '%;'"
                                        />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- BODY COMPACTO -->
                    <div class="sod-compact-body">

                        <div class="sod-main-grid">

                            <!-- MATERIAL COMO FICHA, NO COMO CARDS -->
                            <section class="sod-card sod-card--material-sheet" t-if="hasLotInfo">
                                <div class="sod-card__title">
                                    <i class="fa fa-cube"/>
                                    <span>Material</span>
                                </div>

                                <div class="sod-material-sheet">
                                    <div class="sod-material-main">
                                        <strong t-esc="lotInfo.product_name || 'Producto sin nombre'"/>
                                        <span>
                                            Lote <b t-esc="lotInfo.lot_name || '—'"/>
                                        </span>
                                    </div>

                                    <div class="sod-material-lines">
                                        <div class="sod-line-item">
                                            <span>Cantidad</span>
                                            <strong>
                                                <t t-esc="formatNumber(lotInfo.quantity)"/>
                                                <t t-esc="lotUnitLabel"/>
                                            </strong>
                                        </div>

                                        <div class="sod-line-item" t-if="lotInfo.dimensions">
                                            <span>Dimensiones</span>
                                            <strong t-esc="lotInfo.dimensions"/>
                                        </div>

                                        <div class="sod-line-item">
                                            <span>Ubicación</span>
                                            <strong t-esc="shortLocation"/>
                                        </div>

                                        <div class="sod-line-item" t-if="lotInfo.bloque">
                                            <span>Bloque</span>
                                            <strong t-esc="lotInfo.bloque"/>
                                        </div>

                                        <div class="sod-line-item" t-if="lotInfo.contenedor">
                                            <span>Contenedor</span>
                                            <strong t-esc="lotInfo.contenedor"/>
                                        </div>

                                        <div class="sod-line-item" t-if="lotInfo.atado">
                                            <span>Atado</span>
                                            <strong t-esc="lotInfo.atado"/>
                                        </div>

                                        <div class="sod-line-item" t-if="lotInfo.numero_placa">
                                            <span>N. placa</span>
                                            <strong t-esc="lotInfo.numero_placa"/>
                                        </div>

                                        <div class="sod-line-item sod-line-item--eta" t-if="isTransitLot">
                                            <span>ETA</span>
                                            <strong>
                                                <i class="fa fa-ship"/>
                                                <t t-if="lotInfo.eta" t-esc="formatDate(lotInfo.eta)"/>
                                                <t t-else="">No registrada</t>
                                            </strong>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <!-- VENTA COMPACTA -->
                            <section class="sod-card sod-card--sale-sheet">
                                <div class="sod-card__title">
                                    <i class="fa fa-briefcase"/>
                                    <span>Venta</span>
                                </div>

                                <div class="sod-sale-sheet">
                                    <div class="sod-sale-client">
                                        <span>Cliente</span>
                                        <strong t-esc="primaryOrder.partner_name || '—'"/>
                                    </div>

                                    <div class="sod-sale-lines">
                                        <div>
                                            <span>Vendedor</span>
                                            <strong t-esc="primaryOrder.user_name || '—'"/>
                                        </div>

                                        <div>
                                            <span>Fecha</span>
                                            <strong t-esc="formatDate(primaryOrder.date_order)"/>
                                        </div>

                                        <div t-if="primaryOrder.commitment_date">
                                            <span>Compromiso</span>
                                            <strong t-esc="formatDate(primaryOrder.commitment_date)"/>
                                        </div>
                                    </div>
                                </div>
                            </section>

                        </div>

                        <!-- DESGLOSE DE PAGO -->
                        <section class="sod-card sod-card--payment-detail">
                            <div class="sod-card__title sod-card__title--payment">
                                <i class="fa fa-credit-card"/>
                                <span>Desglose de pago</span>
                            </div>

                            <div class="sod-payment-grid">
                                <div class="sod-payment-cell">
                                    <span>Total</span>
                                    <strong t-esc="formatCurrency(primaryOrder.amount_total, primaryOrder.currency_symbol)"/>
                                </div>

                                <div class="sod-payment-cell">
                                    <span>Pagado</span>
                                    <strong t-esc="formatCurrency(primaryOrder.amount_paid, primaryOrder.currency_symbol)"/>
                                </div>

                                <div class="sod-payment-cell">
                                    <span>Pendiente</span>
                                    <strong t-esc="formatCurrency(primaryOrder.amount_pending, primaryOrder.currency_symbol)"/>
                                </div>

                                <div class="sod-payment-cell">
                                    <span>Facturas</span>
                                    <strong t-esc="primaryOrder.invoice_count || 0"/>
                                </div>
                            </div>
                        </section>

                    </div>
                </t>
            </div>

            <t t-set-slot="footer">
                <button class="btn sod-close-btn" t-on-click="props.close">
                    <i class="fa fa-times me-2"/>
                    Cerrar
                </button>
            </t>
        </Dialog>
    </t>

</templates>