<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="inventory_visual_enhanced.SaleOrderDialog" owl="1">
        <Dialog size="'xl'" title="''" contentClass="'o_sale_order_dialog_content o_sale_order_dialog_content_wood'">
            <div class="o_sale_order_dialog o_sale_order_dialog_premium o_sale_order_dialog_wood">

                <t t-if="!hasOrders">
                    <div class="sod-empty">
                        <button class="sod-floating-close" type="button" t-on-click="props.close" title="Cerrar">
                            <i class="fa fa-times"/>
                        </button>

                        <div class="sod-empty__orb">
                            <i class="fa fa-usd"/>
                        </div>

                        <h3>No hay orden de venta vinculada</h3>
                        <p>
                            El lote fue marcado como vendido, pero no se recibió información de la orden.
                        </p>
                    </div>
                </t>

                <t t-else="">
                    <!-- HERO -->
                    <div class="sod-hero">
                        <button class="sod-floating-close sod-floating-close--hero" type="button" t-on-click="props.close" title="Cerrar">
                            <i class="fa fa-times"/>
                        </button>

                        <div class="sod-hero__pattern"/>
                        <div class="sod-hero__grain"/>

                        <div class="sod-hero__content">
                            <div class="sod-hero__left">
                                <div class="sod-hero__icon">
                                    <i class="fa fa-usd"/>
                                </div>

                                <div class="sod-hero__copy">
                                    <span class="sod-eyebrow">Venta vinculada</span>
                                    <h2>Información comercial del lote</h2>
                                    <p>
                                        Datos esenciales de la orden de venta, pago y saldo pendiente.
                                    </p>
                                </div>
                            </div>

                            <div class="sod-hero__right">
                                <div class="sod-hero-metric">
                                    <span class="sod-hero-metric__label">Referencia</span>
                                    <strong t-if="orderCount === 1" t-esc="orders[0].name"/>
                                    <strong t-else="" t-esc="orderCountLabel"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- MATERIAL: una sola sección, sin repetir en cada orden -->
                    <div class="sod-material-card" t-if="hasLotInfo">
                        <div class="sod-section-head">
                            <div>
                                <span>Material</span>
                                <strong t-esc="lotInfo.product_name || 'Producto sin nombre'"/>
                            </div>

                            <div class="sod-lot-chip">
                                <i class="fa fa-barcode"/>
                                <t t-esc="lotInfo.lot_name || 'Sin lote'"/>
                            </div>
                        </div>

                        <div class="sod-material-grid">
                            <div class="sod-material-item">
                                <span>Cantidad</span>
                                <strong>
                                    <t t-esc="formatNumber(lotInfo.quantity)"/>
                                    <t t-esc="lotUnitLabel"/>
                                </strong>
                            </div>

                            <div class="sod-material-item" t-if="lotInfo.dimensions">
                                <span>Dimensiones</span>
                                <strong t-esc="lotInfo.dimensions"/>
                            </div>

                            <div class="sod-material-item" t-if="lotInfo.location_name">
                                <span>Ubicación</span>
                                <strong t-esc="lotInfo.location_name"/>
                            </div>

                            <div class="sod-material-item" t-if="lotInfo.bloque">
                                <span>Bloque</span>
                                <strong t-esc="lotInfo.bloque"/>
                            </div>

                            <div class="sod-material-item" t-if="lotInfo.contenedor">
                                <span>Contenedor</span>
                                <strong t-esc="lotInfo.contenedor"/>
                            </div>

                            <div class="sod-material-item" t-if="lotInfo.atado">
                                <span>Atado</span>
                                <strong t-esc="lotInfo.atado"/>
                            </div>

                            <div class="sod-material-item" t-if="lotInfo.numero_placa">
                                <span>N. placa</span>
                                <strong t-esc="lotInfo.numero_placa"/>
                            </div>

                            <div class="sod-material-item sod-material-item--eta" t-if="isTransitLot">
                                <span>ETA</span>
                                <strong>
                                    <i class="fa fa-ship"/>
                                    <t t-if="lotInfo.eta" t-esc="formatDate(lotInfo.eta)"/>
                                    <t t-else="">No registrada</t>
                                </strong>
                            </div>
                        </div>
                    </div>

                    <!-- ÓRDENES -->
                    <div class="sod-orders">
                        <t t-foreach="orders" t-as="order" t-key="order.id">
                            <div class="sod-order-card">

                                <div class="sod-order-card__top">
                                    <div class="sod-order-card__identity">
                                        <div class="sod-avatar" t-esc="getInitials(order.partner_name)"/>

                                        <div>
                                            <div class="sod-order-name">
                                                <i class="fa fa-file-text-o"/>
                                                <span t-esc="order.name"/>
                                            </div>
                                            <div class="sod-order-subtitle">
                                                Orden de venta relacionada
                                            </div>
                                        </div>
                                    </div>

                                    <button
                                        type="button"
                                        class="sod-open-btn"
                                        t-on-click="(ev) => this.openSaleOrder(order.id, ev)"
                                        title="Abrir orden de venta"
                                    >
                                        <i class="fa fa-external-link"/>
                                        Abrir orden
                                    </button>
                                </div>

                                <div class="sod-order-card__body">
                                    <!-- Datos comerciales mínimos -->
                                    <div class="sod-info-panel">
                                        <div class="sod-info-item">
                                            <span>
                                                <i class="fa fa-user"/>
                                                Cliente
                                            </span>
                                            <strong t-esc="order.partner_name || '—'"/>
                                        </div>

                                        <div class="sod-info-item">
                                            <span>
                                                <i class="fa fa-id-badge"/>
                                                Vendedor
                                            </span>
                                            <strong t-esc="order.user_name || '—'"/>
                                        </div>

                                        <div class="sod-info-item">
                                            <span>
                                                <i class="fa fa-calendar"/>
                                                Fecha
                                            </span>
                                            <strong t-esc="formatDate(order.date_order)"/>
                                        </div>

                                        <div class="sod-info-item" t-if="order.commitment_date">
                                            <span>
                                                <i class="fa fa-clock-o"/>
                                                Compromiso
                                            </span>
                                            <strong t-esc="formatDate(order.commitment_date)"/>
                                        </div>
                                    </div>

                                    <!-- Pago -->
                                    <div class="sod-payment-panel">
                                        <div class="sod-payment-head">
                                            <span t-att-class="getPaymentBadgeClass(order.payment_status)">
                                                <i t-attf-class="fa #{getPaymentIcon(order.payment_status)}"/>
                                                <t t-esc="order.payment_label"/>
                                            </span>

                                            <strong class="sod-payment-percent" t-esc="formatPercent(order.payment_percentage)"/>
                                        </div>

                                        <div class="sod-payment-progress">
                                            <div
                                                class="sod-payment-progress__bar"
                                                t-att-style="'width: ' + clampPercentage(order.payment_percentage) + '%;'"
                                            />
                                        </div>

                                        <div class="sod-payment-grid">
                                            <div class="sod-payment-cell">
                                                <span>Total</span>
                                                <strong t-esc="formatCurrency(order.amount_total, order.currency_symbol)"/>
                                            </div>

                                            <div class="sod-payment-cell">
                                                <span>Pagado</span>
                                                <strong t-esc="formatCurrency(order.amount_paid, order.currency_symbol)"/>
                                            </div>

                                            <div class="sod-payment-cell">
                                                <span>Pendiente</span>
                                                <strong t-esc="formatCurrency(order.amount_pending, order.currency_symbol)"/>
                                            </div>

                                            <div class="sod-payment-cell">
                                                <span>Facturas</span>
                                                <strong t-esc="order.invoice_count || 0"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </t>
                    </div>
                </t>
            </div>

            <t t-set-slot="footer">
                <button class="btn sod-close-btn" t-on-click="props.close">
                    <i class="fa fa-times me-2"/>
                    Cerrar
                </button>
            </t>
        </Dialog>
    </t>

</templates>