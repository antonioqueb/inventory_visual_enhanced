<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="inventory_visual_enhanced.NotesDialog" owl="1">
        <Dialog size="'lg'" contentClass="'ivh-notes-dialog-shell'">
            <div class="o_notes_dialog">

                <!-- Botón de cierre propio -->
                <button class="ivh-notes-close" type="button" t-on-click="props.close" title="Cerrar">
                    <i class="fa fa-times"></i>
                </button>

                <!-- Header premium -->
                <div class="ivh-notes-hero">
                    <div class="ivh-notes-hero__icon">
                        <i class="fa fa-cube"></i>
                    </div>

                    <div class="ivh-notes-hero__content">
                        <div class="ivh-notes-hero__eyebrow">
                            Notas especiales del lote
                        </div>

                        <h2 class="ivh-notes-hero__title">
                            <t t-esc="notesData.product_name"/>
                        </h2>

                        <div class="ivh-notes-hero__meta">
                            <span>
                                <i class="fa fa-barcode"></i>
                                Lote:
                                <strong t-esc="notesData.lot_name"></strong>
                            </span>
                        </div>
                    </div>
                </div>

                <!-- MODO VISUALIZACIÓN -->
                <t t-if="hasNotes and !state.isEditing">
                    <div class="ivh-notes-card">
                        <div class="ivh-notes-card__header">
                            <h5>
                                <i class="fa fa-exclamation-triangle"></i>
                                Notas y detalles especiales
                            </h5>
                        </div>

                        <div class="ivh-notes-card__body">
                            <div class="ivh-notes-paper">
                                <t t-esc="state.notes"/>
                            </div>
                        </div>
                    </div>

                    <div class="ivh-notes-actions">
                        <button
                            class="btn ivh-notes-primary-btn"
                            t-on-click="toggleEdit"
                        >
                            <i class="fa fa-edit"></i>
                            Editar Notas
                        </button>
                    </div>
                </t>

                <!-- MODO EDICIÓN -->
                <t t-if="!hasNotes or state.isEditing">
                    <div class="ivh-notes-editor">
                        <label class="ivh-notes-label">
                            <i class="fa fa-edit"></i>
                            <t t-if="hasNotes">Editar notas y detalles especiales</t>
                            <t t-else="">Agregar notas y detalles especiales</t>
                        </label>

                        <textarea
                            class="form-control ivh-notes-textarea"
                            rows="12"
                            placeholder="Ej: &#10;- Placa con barreno, grietas visibles en el borde derecho.&#10;- Color irregular, presenta manchas oscuras.&#10;- Requiere corte especial para evitar desperdicios.&#10;- Estado general: Bueno, sin daños significativos.&#10;- Observaciones: Cortar con cuidado para evitar más daños."
                            t-model="state.notes"
                            t-on-input="onNotesChange"
                        ></textarea>

                        <div class="ivh-notes-help">
                            <div class="ivh-notes-help__icon">
                                <i class="fa fa-info-circle"></i>
                            </div>

                            <div class="ivh-notes-help__content">
                                <strong>¿Qué puedes incluir?</strong>
                                <ul>
                                    <li>Defectos físicos: roturas, barrenos o grietas.</li>
                                    <li>Características visuales: vetas, manchas o colores irregulares.</li>
                                    <li>Estado general de la placa.</li>
                                    <li>Observaciones del proceso de corte.</li>
                                    <li>Cualquier detalle relevante para producción o venta.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <t t-set-slot="footer">
                <!-- Modo visualización -->
                <t t-if="hasNotes and !state.isEditing">
                    <button class="btn ivh-notes-secondary-btn" t-on-click="props.close">
                        <i class="fa fa-times"></i>
                        Cerrar
                    </button>
                </t>

                <!-- Modo edición -->
                <t t-if="!hasNotes or state.isEditing">
                    <button
                        class="btn ivh-notes-secondary-btn"
                        t-on-click="hasNotes ? toggleEdit : props.close"
                    >
                        <i class="fa fa-times"></i>
                        Cancelar
                    </button>

                    <button
                        class="btn ivh-notes-primary-btn"
                        t-on-click="saveNotes"
                        t-att-disabled="state.isSaving"
                    >
                        <t t-if="!state.isSaving">
                            <i class="fa fa-save"></i>
                            Guardar Notas
                        </t>

                        <t t-else="">
                            <i class="fa fa-spinner fa-spin"></i>
                            Guardando...
                        </t>
                    </button>
                </t>
            </t>
        </Dialog>
    </t>

</templates>