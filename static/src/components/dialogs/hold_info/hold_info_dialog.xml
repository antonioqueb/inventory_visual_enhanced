<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="inventory_visual_enhanced.HoldInfoDialog" owl="1">
        <Dialog size="'xl'" title="''" contentClass="'o_hold_info_dialog_content o_hold_info_dialog_content_wood'">
            <div class="o_hold_info_dialog o_hold_info_dialog_wood">

                <button class="hold-info-floating-close" type="button" t-on-click="props.close" title="Cerrar">
                    <i class="fa fa-times"/>
                </button>

                <!-- HERO -->
                <div class="hold-info-hero">
                    <div class="hold-info-hero__grain"/>
                    <div class="hold-info-hero__content">
                        <div class="hold-info-hero__left">
                            <div class="hold-info-hero__icon">
                                <i class="fa fa-hand-paper-o"/>
                            </div>

                            <div class="hold-info-hero__copy">
                                <span class="hold-info-eyebrow">Apartado activo</span>
                                <h2>Material reservado</h2>
                                <p>
                                    Este lote está apartado actualmente y no está disponible para otros clientes
                                    hasta que se libere o expire el apartado.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- QUICK SUMMARY -->
                <div class="hold-info-summary">
                    <div class="hold-info-stat hold-info-stat--product">
                        <span>Producto</span>
                        <strong t-esc="detailData.product_name"/>
                    </div>

                    <div class="hold-info-stat">
                        <span>Lote</span>
                        <strong t-esc="detailData.lot_name"/>
                    </div>

                    <div class="hold-info-stat">
                        <span>Cantidad</span>
                        <strong><t t-esc="detailData.quantity"/> m²</strong>
                    </div>

                    <div class="hold-info-stat hold-info-stat--status">
                        <span>Estatus</span>
                        <strong>Apartado</strong>
                    </div>
                </div>

                <!-- ALERT -->
                <div class="hold-info-status">
                    <div class="hold-info-status__icon">
                        <i class="fa fa-exclamation-triangle"/>
                    </div>
                    <div class="hold-info-status__copy">
                        <strong>Este lote está apartado actualmente</strong>
                        <p>
                            El material está reservado y no debe asignarse a otra operación comercial mientras
                            el apartado permanezca activo.
                        </p>
                    </div>
                </div>

                <!-- HORIZONTAL LAYOUT -->
                <div class="hold-info-main">

                    <!-- LEFT: DATOS DEL APARTADO -->
                    <div class="hold-info-main__left">

                        <div class="hold-info-card">
                            <div class="hold-info-card__header">
                                <i class="fa fa-briefcase"/>
                                <span>Datos del apartado</span>
                            </div>

                            <div class="hold-info-data-grid">
                                <div class="hold-info-data-item hold-info-data-item--wide">
                                    <span>Cliente</span>
                                    <strong>
                                        <i class="fa fa-user-circle"/>
                                        <t t-esc="holdInfo.partner_name"/>
                                    </strong>
                                </div>

                                <div class="hold-info-data-item" t-if="holdInfo.proyecto_nombre">
                                    <span>Proyecto</span>
                                    <strong>
                                        <i class="fa fa-folder-open-o"/>
                                        <t t-esc="holdInfo.proyecto_nombre"/>
                                    </strong>
                                </div>

                                <div class="hold-info-data-item" t-if="holdInfo.arquitecto_nombre">
                                    <span>Arquitecto</span>
                                    <strong>
                                        <i class="fa fa-user-circle-o"/>
                                        <t t-esc="holdInfo.arquitecto_nombre"/>
                                    </strong>
                                </div>

                                <div class="hold-info-data-item" t-if="holdInfo.vendedor_nombre">
                                    <span>Vendedor</span>
                                    <strong>
                                        <i class="fa fa-id-badge"/>
                                        <t t-esc="holdInfo.vendedor_nombre"/>
                                    </strong>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- RIGHT: VIGENCIA + INFORMACIÓN DEL LOTE -->
                    <div class="hold-info-main__right">

                        <!-- VIGENCIA ARRIBA DE INFORMACIÓN DEL LOTE -->
                        <div class="hold-info-card">
                            <div class="hold-info-card__header">
                                <i class="fa fa-calendar"/>
                                <span>Vigencia</span>
                            </div>

                            <div class="hold-info-date-grid">
                                <div class="hold-info-side-item">
                                    <span>Inicio</span>
                                    <strong>
                                        <i class="fa fa-calendar-check-o"/>
                                        <t t-esc="holdInfo.fecha_inicio"/>
                                    </strong>
                                </div>

                                <div class="hold-info-side-item">
                                    <span>Expiración</span>
                                    <strong>
                                        <i class="fa fa-calendar-times-o"/>
                                        <t t-esc="holdInfo.fecha_expiracion"/>
                                    </strong>
                                </div>
                            </div>
                        </div>

                        <!-- INFORMACIÓN DEL LOTE AMPLIADA -->
                        <div class="hold-info-card hold-info-lot-card">
                            <div class="hold-info-card__header">
                                <i class="fa fa-cube"/>
                                <span>Información completa del lote</span>
                            </div>

                            <div class="hold-info-lot-grid">

                                <div class="hold-info-lot-item hold-info-lot-item--wide">
                                    <span>Ubicación</span>
                                    <strong>
                                        <i class="fa fa-map-marker"/>
                                        <t t-esc="detailData.location_name"/>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item">
                                    <span>Cantidad total</span>
                                    <strong>
                                        <i class="fa fa-balance-scale"/>
                                        <t t-esc="detailData.quantity"/> m²
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.reserved_quantity">
                                    <span>Cantidad reservada</span>
                                    <strong>
                                        <i class="fa fa-lock"/>
                                        <t t-esc="detailData.reserved_quantity"/> m²
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.grosor">
                                    <span>Grosor</span>
                                    <strong>
                                        <i class="fa fa-compress"/>
                                        <t t-esc="detailData.grosor"/> cm
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.alto">
                                    <span>Alto</span>
                                    <strong>
                                        <i class="fa fa-arrows-v"/>
                                        <t t-esc="detailData.alto"/> m
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.ancho">
                                    <span>Ancho</span>
                                    <strong>
                                        <i class="fa fa-arrows-h"/>
                                        <t t-esc="detailData.ancho"/> m
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item hold-info-lot-item--wide" t-if="detailData.grosor or detailData.alto or detailData.ancho">
                                    <span>Dimensiones completas</span>
                                    <strong>
                                        <i class="fa fa-expand"/>
                                        <t t-if="detailData.grosor"><t t-esc="detailData.grosor"/>cm</t>
                                        <t t-if="detailData.grosor and (detailData.alto or detailData.ancho)"> × </t>
                                        <t t-if="detailData.alto"><t t-esc="detailData.alto"/>m</t>
                                        <t t-if="detailData.alto and detailData.ancho"> × </t>
                                        <t t-if="detailData.ancho"><t t-esc="detailData.ancho"/>m</t>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.tipo">
                                    <span>Tipo</span>
                                    <strong>
                                        <i class="fa fa-tag"/>
                                        <t t-esc="detailData.tipo"/>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.color">
                                    <span>Color</span>
                                    <strong>
                                        <i class="fa fa-tint"/>
                                        <t t-esc="detailData.color"/>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.bloque">
                                    <span>Bloque</span>
                                    <strong>
                                        <i class="fa fa-th-large"/>
                                        <t t-esc="detailData.bloque"/>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.atado">
                                    <span>Atado</span>
                                    <strong>
                                        <i class="fa fa-object-group"/>
                                        <t t-esc="detailData.atado"/>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.contenedor">
                                    <span>Contenedor</span>
                                    <strong>
                                        <i class="fa fa-archive"/>
                                        <t t-esc="detailData.contenedor"/>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item" t-if="detailData.numero_placa">
                                    <span>Número de placa</span>
                                    <strong>
                                        <i class="fa fa-hashtag"/>
                                        <t t-esc="detailData.numero_placa"/>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item hold-info-lot-item--wide" t-if="detailData.pedimento">
                                    <span>Pedimento</span>
                                    <strong>
                                        <i class="fa fa-file-text-o"/>
                                        <t t-esc="detailData.pedimento"/>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item hold-info-lot-item--wide" t-if="detailData.referencia_proveedor">
                                    <span>Referencia proveedor</span>
                                    <strong>
                                        <i class="fa fa-truck"/>
                                        <t t-esc="detailData.referencia_proveedor"/>
                                    </strong>
                                </div>

                                <div class="hold-info-lot-item hold-info-lot-item--wide" t-if="detailData.detalles_placa">
                                    <span>Detalles físicos del lote</span>
                                    <strong>
                                        <i class="fa fa-info-circle"/>
                                        <t t-esc="detailData.detalles_placa"/>
                                    </strong>
                                </div>

                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <t t-set-slot="footer">
                <button class="hold-info-close-button" type="button" t-on-click="props.close">
                    <i class="fa fa-times"/>
                    Cerrar
                </button>
            </t>
        </Dialog>
    </t>

</templates>